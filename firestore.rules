rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. 공연 히스토리 컬렉션 보안 규칙
    match /history/{postId} {
      // 비로그인 사용자도 히스토리 포스트 조회 가능
      allow read: if true;
      // 오직 로그인한 인증된 관리자 계정만 등록/수정/삭제 가능
      allow write, update, delete: if request.auth != null;
    }
    
    // 2. 예약 및 견적 문의 컬렉션 보안 규칙
    match /inquiries/{inquiryId} {
      // 일반 방문자(비로그인)가 문의 폼을 통해 신청서(Create)를 접수할 수 있도록 허용
      allow create: if true;
      // 오직 로그인한 인증된 관리자 계정만 전체 목록 조회(Read), 읽음 처리(Update), 문의 글 삭제(Delete) 가능
      allow read, update, delete: if request.auth != null;
    }

    // 3. 공연 프로그램 컬렉션 보안 규칙
    match /programs/{programId} {
      // 비로그인 사용자도 프로그램 목록/상세 조회 가능
      allow read: if true;
      // 오직 로그인한 인증된 관리자 계정만 등록/수정/삭제 가능
      allow write, update, delete: if request.auth != null;
    }
  }
}
